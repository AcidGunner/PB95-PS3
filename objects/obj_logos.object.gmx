            <string>audio_channel_num(10);
global.started=0;
global.placeholder=1;
game_reset();
load_assets();
randomize();

if global.placeholder==1 show_message("ORIGINAL ASSETS NOT FOUND. PLACEHOLDER ASSETS ARE USED INSTEAD.");

if !global.placeholder
{
    spr_logo_shs = sprite_add(img_path+"shslogo.png",1,false,false,256,256);
    spr_logo_icoeye = sprite_add(img_path+"icoheart.png",1,false,false,50,50);
}
else
{
    spr_logo_shs = placeholder_shslogo;
    spr_logo_icoeye = placeholder_icoheart;
}

x=room_width/2;
y=room_height/2;
image_speed=0.34;
image_alpha=0;
sprite_index=spr_logo_shs;
fade=0;
temp=0;

if false
{
    alarm[4]=1;
    exit;
}

alarm[0]=2.1*30;
alarm[2]=1.6*30;
</string>
