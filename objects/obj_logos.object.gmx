            <string>image_blend=c_white;
if fade=0 image_alpha=lerp(image_alpha,1,0.05) else image_alpha=lerp(image_alpha,0,0.2);

if sprite_index!=-1
{
    if sprite_index!=spr_logo_icoeye draw_self()
    else
    {
        temp+=image_speed;
        var temp2=floor(temp);
        var xx = (temp2 mod 5) * 100;
        var yy = (temp2 div 5) * 100;
        draw_sprite_part_ext(spr_logo_icoeye,0,xx,yy,100,100,x-100,y-100,2,2,c_white,image_alpha);
    }
}

draw_set_font(fnt_main_big);
draw_set_alpha(image_alpha);
draw_set_valign(fa_center);
draw_set_halign(fa_middle);
if sprite_index==spr_logo_acid
{
    draw_text(x,y-200,"THIS FAN-MADE PS3 EDITION BY# #ACIDNT3.1");
    draw_text(x,y+200,"PRODUCTIONS# #MADE FOR ACIDPS3 PROJECT");
}
else if sprite_index==-1 draw_text_ext(x,y,ds_map_find_value(global.lang,"Disclaimer"),-1,400);
else draw_text(x,y-200,"NOT AN OFFICIAL PRODUCT OF")

draw_set_alpha(1);
</string>
