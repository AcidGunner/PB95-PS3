<!--This Document is generated by GameMaker, if you edit it by hand then you do so at your own risk!-->
<object>
  <spriteName>&lt;undefined&gt;</spriteName>
  <solid>0</solid>
  <visible>-1</visible>
  <depth>0</depth>
  <persistent>-1</persistent>
  <parentName>&lt;undefined&gt;</parentName>
  <maskName>&lt;undefined&gt;</maskName>
  <events>
    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>///Control values

//ACIDNTCONTROLINPUT v1.0

//Default
up=0;
down=0;
right=0;
left=0;
start=0;
lef=0;
rig=0;
dow=0;
upp=0;
a=0;
b=0;
m=0;
m_h=0;
m_r=0;
mx=0;
my=0;

sns=2;

//PS3 ONLY VALUES
gmin=0.4;
gmax=0.9;
stick_rh=0;
stick_rv=0;
cursor_x=stick_rh;
cursor_y=stick_rv;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>//Prepare the CONSOLE MOVEMENTS!!!!
if (!variable_global_exists("prev_stick_h")) {
    global.prev_stick_h = 0;
    global.prev_stick_v = 0;
}

var stick_h=gamepad_axis_value(0,gp_axislh);
var stick_v=gamepad_axis_value(0,gp_axislv);
var stick_rh=gamepad_axis_value(0,gp_axisrh);
var stick_rv=gamepad_axis_value(0,gp_axisrv);

//Last config!
if os_type==os_ps3
{
    up=gamepad_button_check(0,gp_padu) or stick_v&lt;=-gmin;
    down=gamepad_button_check(0,gp_padd) or stick_v&gt;=gmin;
    right=gamepad_button_check(0,gp_padr) or stick_h&gt;=gmin;
    left=gamepad_button_check(0,gp_padl) or stick_h&lt;=-gmin;
    start=gamepad_button_check_pressed(0,gp_start);
    lef=gamepad_button_check_pressed(0,gp_padl) or (stick_h&lt;=-gmin &amp;&amp; global.prev_stick_h&gt;-gmin);
    rig=gamepad_button_check_pressed(0,gp_padr) or (stick_h&gt;=gmin &amp;&amp; global.prev_stick_h&lt;gmin);
    dow=gamepad_button_check_pressed(0,gp_padd) or (stick_v&gt;=gmin &amp;&amp; global.prev_stick_v&lt;gmin);
    upp=gamepad_button_check_pressed(0,gp_padu) or (stick_v&lt;=-gmin &amp;&amp; global.prev_stick_v&gt;-gmin);
    a=gamepad_button_check_pressed(0,gp_face1);
    b=gamepad_button_check(0,gp_face3);
    m=gamepad_button_check_pressed(0,gp_face1);
    m_h=gamepad_button_check(0,gp_face1);
    m_r=gamepad_button_check_released(0,gp_face1);
    
    //if stick_rh&lt;=gmax &amp;&amp; stick_rh&gt;=gmin mx=stick_rh;
    //if stick_rv&lt;=gmax &amp;&amp; stick_rv&gt;=gmin my=stick_rv;
    
    cursor_x=stick_rh
    cursor_y=stick_rv
    global.prev_stick_h = stick_h;
    global.prev_stick_v = stick_v;
    global.prev_stick_rh = stick_rh;
    global.prev_stick_rv = stick_rv;
    
    mx+=cursor_x*(5*sns);
    my+=cursor_y*(5*sns);
}
else
{
    up=keyboard_check(ord('W'));
    down=keyboard_check(ord('S'));
    right=keyboard_check(ord('D'));
    left=keyboard_check(ord('A'));
    start=keyboard_check_pressed(vk_enter);
    lef=keyboard_check_pressed(ord('A'));
    rig=keyboard_check_pressed(ord('D'));
    dow=keyboard_check_pressed(ord('S'));
    upp=keyboard_check_pressed(ord('W'));
    a=keyboard_check(ord('E'));
    b=keyboard_check(vk_lshift);
    m=mouse_check_button_pressed(mb_left);
    m_h=mouse_check_button(mb_left);
    m_r=mouse_check_button_released(mb_left);
    
    cursor_x=window_mouse_get_x();
    cursor_y=window_mouse_get_y();
    
    mx=mouse_x;
    my=mouse_y;
}
</string>
          </argument>
        </arguments>
      </action>
    </event>
  </events>
  <PhysicsObject>0</PhysicsObject>
  <PhysicsObjectSensor>0</PhysicsObjectSensor>
  <PhysicsObjectShape>0</PhysicsObjectShape>
  <PhysicsObjectDensity>0.5</PhysicsObjectDensity>
  <PhysicsObjectRestitution>0.100000001490116</PhysicsObjectRestitution>
  <PhysicsObjectGroup>0</PhysicsObjectGroup>
  <PhysicsObjectLinearDamping>0.100000001490116</PhysicsObjectLinearDamping>
  <PhysicsObjectAngularDamping>0.100000001490116</PhysicsObjectAngularDamping>
  <PhysicsObjectFriction>0.200000002980232</PhysicsObjectFriction>
  <PhysicsObjectAwake>-1</PhysicsObjectAwake>
  <PhysicsObjectKinematic>0</PhysicsObjectKinematic>
  <PhysicsShapePoints/>
</object>
