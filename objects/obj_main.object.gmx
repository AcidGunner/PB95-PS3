            <kind>1</kind>
            <string>draw_self();
draw_set_valign(fa_center);
draw_set_halign(fa_middle);

draw_set_colour(c_gray);
draw_rectangle(x-144,y-12,x+144,y+12,false)
for (var i = 0; i &lt; ds_list_size(global.progress); i++)
{
    var _x = (x-144)+(i*14.4);
    draw_set_colour(ds_list_find_value(global.progress,i));
    draw_rectangle(_x,y-12,_x+14.4,y+12,false);
}
draw_set_colour(c_white);
//draw_healthbar(,global.percent,c_gray,c_blue,c_blue,0,1,0);
draw_text(x,y,string(global.percent)+"%");
draw_set_valign(fa_top);
draw_set_halign(fa_left);
window_set_cursor(cr_none);
</string>
