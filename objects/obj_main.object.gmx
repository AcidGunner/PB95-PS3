        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>if global.percent==100
{
    x=lerp(x,640,0.1);
    y=lerp(y,360,0.1);
}
else
{
    x=obj_input.mx;
    y=obj_input.my;
}

if global.percent=100 &amp;&amp; temp=0 obj_main.alarm[1]=1;
</string>
          </argument>
        </arguments>
