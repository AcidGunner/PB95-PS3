        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_sprite_part_ext(obj_taskbar._gui,0,6,74,182,42,x-150,y-20,1.67,1,c_white,1);
draw_sprite_part_ext(obj_taskbar._gui,0,4,354,122,46,x-144,y-14,2.37,0.6,c_white,1);
draw_set_valign(fa_center);
draw_set_halign(fa_middle);

//draw_set_colour(c_red);
//draw_set_alpha(0.5);
//draw_rectangle(x-144,y-12,x+144,y+12,false);
//draw_set_alpha(1);
for (var i = 0; i &lt; ds_list_size(global.progress); i++)
{
    var _x = (x-144)+(i*14.4);
    draw_set_colour(ds_list_find_value(global.progress,i));
    draw_rectangle(_x+0.1,y-12,_x+14.4-0.1,y+12,false);
}
draw_set_colour(c_white);
draw_text(x,y,string(global.percent)+"%");
draw_set_valign(fa_top);
draw_set_halign(fa_left);

if draw_txt=1 draw_text(x,y-40,check_patterns());
</string>
          </argument>
        </arguments>
