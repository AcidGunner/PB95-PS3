        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>draw_set_colour(colour);
draw_rectangle(x-6,y-12,x+6,y+12,false);
draw_set_colour(c_white);
</string>
          </argument>
        </arguments>
      </action>
    </event>
