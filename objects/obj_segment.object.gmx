    <event eventtype="0" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>yspd=5+(global.percent/25);
if irandom_range(0,1)==0
{
    colour=$7F0000;
    wobbly=4;
}
else
{
    colour=$1E93F7;
    wobbly=1;
}

if irandom_range(0,25)==0
{
    colour=$3fc68c;
    wobbly=7;
    yspd=9;
}

if irandom_range(0,3)==0
{
    colour=$2C26C1;
    wobbly=7;
}

//if irandom_range(0,4)==0   PINK SEGMENT NEEDS TO BE PATCHED!!!
//{
//    colour=$FF00FF;
//    wobbly=4;
//}

if irandom_range(0,5)==0
{
    colour=$9F9E9F;
    wobbly=0;
}

x=irandom_range(20,1260);
temp=1;
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="3" enumb="0">
      <action>
        <libid>1</libid>
        <id>603</id>
        <kind>7</kind>
        <userelative>0</userelative>
        <isquestion>0</isquestion>
        <useapplyto>-1</useapplyto>
        <exetype>2</exetype>
        <functionname></functionname>
        <codestring></codestring>
        <whoName>self</whoName>
        <relative>0</relative>
        <isnot>0</isnot>
        <arguments>
          <argument>
            <kind>1</kind>
            <string>y+=yspd;
if y&gt;760 instance_destroy();
if global.percent=100 instance_destroy();

var wx=obj_main.x;
var wy=obj_main.y;

if irandom_range(0,10)==0 temp=-temp;
x+=wobbly*temp;

var pos=14.4*((global.percent-50)/5);
if point_in_rectangle(x,y,wx+pos,wy-12,wx+144,wy+12)
{
    if colour==$1E93F7
    {
        global.percent+=5;
        ds_list_add(global.progress,colour);
        audio_play_sound(snd_jump3,1,false)
    }
    else if colour==$3fc68c
    {
        global.percent=100;
        ds_list_clear(global.progress)
        repeat(20) ds_list_add(global.progress,$7F0000);
        obj_main.alarm[1]=1;
    }
    else if colour==$2C26C1
    {
        game_end();
        audio_stop_all();
        instance_destroy(all);
        instance_destroy();
    }
    else if colour==$FF00FF
    {
        if global.percent&gt;0 global.percent-=5;
        ds_list_delete(global.progress,ds_list_size(global.progress));
    }
    else if colour==$9F9E9F
    {
        show_debug_message("lol");
    }
    else
    {
        global.percent+=5;
        ds_list_add(global.progress,colour);
        audio_play_sound(snd_jump1,1,false)
    }
    instance_destroy();
}
else if point_in_rectangle(x,y,wx-144,wy-12,wx+pos,wy+12)
{
    audio_play_sound(snd_miss,1,false);
    instance_destroy();
};
</string>
          </argument>
        </arguments>
      </action>
    </event>
    <event eventtype="8" enumb="0">
