            <kind>1</kind>
            <string>if !global.placeholder
{
    if global.skin_id==0
    {
        _gui=sprite_add(img_path+"skins/95/gui.png",1,false,false,0,0);
        snd_startup = audio_create_stream(snd_path+"intro_P95.ogg");
