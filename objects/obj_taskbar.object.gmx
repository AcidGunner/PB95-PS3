        <arguments>
          <argument>
            <kind>1</kind>
            <string>if !global.placeholder &amp;&amp; !audio_is_playing(snd_startup) audio_destroy_stream(snd_startup);

if obj_input.mx&gt;7 &amp;&amp; obj_input.mx&lt;7+122 &amp;&amp; obj_input.my&gt;720-44-7 &amp;&amp; obj_input.my&lt;720-7
{
    if obj_input.m_h pressed=1 else pressed=0;
    
    if obj_input.m_r &amp;&amp; !global.started
    {
        instance_create(room_width/2,room_height/2,obj_main);
        global.started=1;
    }
}
else if obj_input.m_r pressed=0;
</string>
