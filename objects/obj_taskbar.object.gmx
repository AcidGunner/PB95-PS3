    {
        _gui=sprite_add(img_path+"skins/95plus/gui.png",1,false,false,0,0);
        snd_startup = audio_create_stream(snd_path+"intro_P96.ogg");
    }
    else if global.skin_id==2
    {
        _gui=sprite_add(img_path+"skins/98/gui.png",1,false,false,0,0);
        snd_startup = audio_create_stream(snd_path+"intro_P98.ogg");
    }
    else if global.skin_id==3
    {
        _gui=sprite_add(img_path+"skins/M/gui.png",1,false,false,0,0);
        snd_startup = audio_create_stream(snd_path+"intro_PMEME.ogg");
    }
    else if global.skin_id==4
    {
        _gui=sprite_add(img_path+"skins/2000/gui.png",1,false,false,0,0);
        snd_startup = audio_create_stream(snd_path+"intro_P2K.ogg");
    }
    _cur=sprite_add(img_path+"cursor1.png",1,false,false,0,0);
}
else
{
    _gui = placeholder_gui;
    snd_startup = placeholder_snd;
    _cur = placeholder_cursor;
}
    
audio_play_sound(snd_startup,0,false);
audio_sound_gain(snd_startup,0.35,0);

pressed=0;
</string>
